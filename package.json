    "@angular/forms": "18.2.14",
    "@angular/platform-browser": "18.2.14",
    "@angular/router": "18.2.14",
    "@emailjs/browser": "^4.4.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.14.10"
  },
  "devDependencies": {
    "@angular/build": "18.2.14",
    "@angular/cli": "18.2.14",
    "@angular/compiler-cli": "18.2.14",
    "@tailwindcss/postcss": "^4.1.12",
    "jsdom": "^27.1.0",
